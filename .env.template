QINIU_ACCESS_KEY=your_access_key
QINIU_SECRET_KEY=your_secret_key
QINIU_BUCKET=your_bucket_name
QINIU_DOWNLOAD_DOMAIN=https://cdn.example.com

# Optional
# Upload endpoint - must be a Qiniu form upload URL, NOT the S3-compatible endpoint
# z0(华东): https://up.qiniup.com or https://up-z0.qiniup.com
# z1(华北): https://up-z1.qiniup.com
# z2(华南): https://up-z2.qiniup.com
# na0(北美): https://up-na0.qiniup.com
QINIU_UPLOAD_URL=https://up.qiniup.com
QINIU_PRIVATE=true
QINIU_AI_API_KEY=
# GitHub personal access token - optional, increases API rate limit from 60 to 5000 req/hour
# Required only if syncing many remote skills or hitting rate limits
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=
